## Descrições de comandos e nomes de menus de contexto
## Usado pelo FluentTranslator para a localização de comandos do Discord

# Descrições de comandos
cmd-desc-ping = Receba uma resposta rápida do bot para verificar se está online.
cmd-desc-invite = Exibe um convite para adicionar o ReQuest ao seu servidor.
cmd-desc-support = Exibe a versão do bot e um link para o servidor de desenvolvimento.
cmd-desc-language = Defina seu idioma preferido para as respostas do bot.
cmd-desc-help = Exibe uma lista de comandos e suas funções.
cmd-desc-admin = Assistente de administração. Apenas para o dono do bot
cmd-desc-config = Menus de Configuração do Servidor (apenas Admins)
cmd-desc-gm = Menus de Mestre de Jogo
cmd-desc-player = Menus do Jogador
cmd-desc-shop = Abre uma loja no canal atual, se houver uma configurada.

# Nomes de menus de contexto
cmd-context-name-trade = Trocar
cmd-context-name-modify-player = Modificar Jogador
cmd-context-name-view-player = Ver Jogador
